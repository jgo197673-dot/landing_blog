# AUBE Gemini Chatbot 환경변수
# Vercel Dashboard → Settings → Environment Variables 에서 설정하세요.

# Google AI Studio에서 발급받은 API Key
GEMINI_API_KEY=your_gemini_api_key_here

# 사용할 Gemini 모델 (기본값: gemini-2.5-flash)
# 추후 gemini-2.5-pro 등으로 변경 가능
GEMINI_MODEL=gemini-2.5-flash

# ────────────────────────────────────
# GA4 설정 (HTML에 직접 입력)
# ────────────────────────────────────
# GA4 Measurement ID는 index.html과 notice.html의
# <script> 태그에서 G-XXXXXXXXXX를 교체하세요.
# 예: G-ABC123DEF4
# 
# Google Analytics → 관리 → 데이터 스트림 → 측정 ID 확인
